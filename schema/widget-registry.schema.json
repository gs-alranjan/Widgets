{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://insided.com/schemas/widget-registry.schema.json",
  "title": "Widget Registry Schema",
  "description": "Schema for validating widget registry JSON",
  "type": "object",
  "required": ["widgets"],
  "properties": {
    "widgets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/widget"
      }
    },
    "importMap": {
      "$ref": "#/definitions/importMap"
    }
  },
  "definitions": {
    "widget": {
      "type": "object",
      "required": ["type", "title"],
      "properties": {
        "version": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "containers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Full width", "Left container", "Sidebar"]
          }
        },
        "imageName": {
          "type": "string"
        },
        "imageSrc": {
          "type": "string",
          "format": "uri"
        },
        "widgetsLibrary": {
          "type": "boolean"
        },
        "settings": {
          "$ref": "#/definitions/widgetSettings"
        },
        "content": {
          "$ref": "#/definitions/widgetContent"
        },
        "configuration": {
          "$ref": "#/definitions/widgetConfiguration"
        },
        "defaultConfig": {
          "type": "object"
        }
      },
      "not": {
        "required": ["imageName", "imageSrc"]
      }
    },
    "widgetSettings": {
      "type": "object",
      "properties": {
        "configurable": {
          "type": "boolean"
        },
        "editable": {
          "type": "boolean"
        },
        "removable": {
          "type": "boolean"
        },
        "shared": {
          "type": "boolean"
        },
        "movable": {
          "type": "boolean"
        },
        "container": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "widgetContent": {
      "type": "object",
      "required": ["endpoint", "method"],
      "properties": {
        "endpoint": {
          "type": "string"
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST"]
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "body": {
          "type": "object"
        },
        "params": {
          "type": "object"
        },
        "cacheStrategy": {
          "type": "string",
          "enum": ["ttl", "no-cache", "none", "permanent"]
        },
        "cacheTtlSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "requiresAuthentication": {
          "type": "boolean"
        }
      }
    },
    "widgetConfiguration": {
      "type": "object",
      "required": ["properties"],
      "properties": {
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/configField"
          }
        }
      }
    },
    "configField": {
      "type": "object",
      "required": ["name", "label", "type"],
      "properties": {
        "name": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": ["string", "null"]
        },
        "type": {
          "type": "string",
          "enum": ["text", "number", "color", "date", "boolean", "select"]
        },
        "defaultValue": {},
        "rules": {
          "$ref": "#/definitions/fieldRules"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/selectOption"
          }
        }
      }
    },
    "fieldRules": {
      "type": "object",
      "properties": {
        "required": {
          "type": "boolean"
        },
        "minLength": {
          "type": "integer",
          "minimum": 0
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0
        },
        "pattern": {
          "type": "string"
        },
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "selectOption": {
      "type": "object",
      "required": ["value", "label"],
      "properties": {
        "value": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "importMap": {
      "type": "object",
      "properties": {
        "imports": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
