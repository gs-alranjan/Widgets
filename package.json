{
  "name": "@insided/custom-widgets",
  "version": "1.0.0",
  "description": "Custom widgets for InSided Community platform",
  "type": "module",
  "scripts": {
    "build": "esbuild src/widgets/welcome-banner/index.ts --bundle --format=esm --outdir=dist --minify",
    "validate": "node scripts/validate-registry.js",
    "dev": "esbuild src/widgets/welcome-banner/index.ts --bundle --format=esm --outdir=dist --watch",
    "serve": "npx http-server dist -p 8080 --cors"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
