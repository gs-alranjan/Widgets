{
  "widgets": [
    {
      "category": "Custom",
      "configuration": {
        "properties": [
          {
            "name": "heading",
            "label": "Heading",
            "type": "text",
            "defaultValue": "Welcome to our Community!",
            "rules": {
              "required": true,
              "maxLength": 100
            }
          },
          {
            "name": "message",
            "label": "Message",
            "type": "text",
            "defaultValue": "Join the conversation, ask questions, and share your knowledge.",
            "rules": {
              "required": false,
              "maxLength": 250
            }
          },
          {
            "name": "ctaLabel",
            "label": "CTA Button Label",
            "type": "text",
            "defaultValue": "Get Started",
            "rules": {
              "required": false,
              "maxLength": 30
            }
          },
          {
            "name": "ctaUrl",
            "label": "CTA Button URL",
            "type": "text",
            "defaultValue": "/getting-started",
            "rules": {
              "required": false
            }
          },
          {
            "name": "backgroundColor",
            "label": "Background Color",
            "type": "color",
            "defaultValue": "#4A90D9"
          },
          {
            "name": "textColor",
            "label": "Text Color",
            "type": "color",
            "defaultValue": "#FFFFFF"
          },
          {
            "name": "layout",
            "label": "Layout Style",
            "type": "select",
            "defaultValue": "centered",
            "options": [
              {
                "value": "centered",
                "label": "Centered"
              },
              {
                "value": "left-aligned",
                "label": "Left Aligned"
              },
              {
                "value": "split",
                "label": "Split"
              }
            ]
          }
        ]
      },
      "containers": [
        "Full width"
      ],
      "defaultConfig": {
        "heading": "Welcome to our Community!",
        "message": "Join the conversation, ask questions, and share your knowledge.",
        "ctaLabel": "Get Started",
        "ctaUrl": "/getting-started",
        "backgroundColor": "#4A90D9",
        "textColor": "#FFFFFF",
        "layout": "centered"
      },
      "description": "A customizable welcome banner widget with heading, message, CTA button, and theming options",
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": false
      },
      "title": "Welcome Banner",
      "version": "1.0.0",
      "widgetsLibrary": true,
      "type": "welcome_banner",
      "source": {
        "path": "widgets/welcome_banner/dist",
        "entry": "content.html"
      },
      "imageSrc": "widgets/welcome_banner/thumbnail.png"
    },
    {
      "category": "Demo",
      "configuration": {
        "properties": [
          {
            "name": "title",
            "type": "text",
            "label": "Title",
            "defaultValue": "React Widget 2.0",
            "rules": {
              "required": true
            }
          },
          {
            "name": "description",
            "type": "text",
            "label": "Description",
            "defaultValue": "A widget built with React and the Widget SDK."
          }
        ]
      },
      "containers": [
        "Full width"
      ],
      "defaultConfig": {
        "title": "React Widget 2.0",
        "description": "A widget built with React and the Widget SDK."
      },
      "description": "A React widget using the ESM module pattern with Widget SDK",
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": false
      },
      "title": "React Widget 2.0",
      "version": "1.0.0",
      "widgetsLibrary": true,
      "type": "react_widget",
      "source": {
        "path": "widgets/react_widget/dist",
        "entry": "index.html"
      },
      "imageSrc": "widgets/react_widget/thumbnail.png"
    }
  ]
}
